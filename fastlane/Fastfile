default_platform(:ios)

# App Store Connect API Key(.p8)로만 인증한다(Apple ID/암호·2FA 자동입력 없음).
# 서명은 -allowProvisioningUpdates 로 xcodebuild가 자동 관리(수동 인증서/프로파일 없음).
def asc_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_API_KEY_PATH"],
    in_house: false
  )
end

WORKSPACE = "ios/App/App.xcworkspace" # Capacitor(CocoaPods) 생성물
PROJECT   = "ios/App/App.xcodeproj"    # 서명 설정을 주입할 대상
SCHEME    = "App"

# Capacitor가 매번 새로 생성하는 프로젝트엔 개발팀(Team)이 안 박혀 있어
# 아카이브가 "requires a development team" 으로 실패한다. 빌드 직전에
# 자동 서명 + 팀 ID를 주입한다(수동 인증서/프로파일 없음, ASC API Key로 자동 관리).
def apply_automatic_signing
  update_code_signing_settings(
    use_automatic_signing: true,
    team_id: ENV["APPLE_TEAM_ID"],
    path: PROJECT,
    targets: ["App"]
  )
end

# 서명은 "export 단계에서만" 한다. 아카이브는 서명 없이(skip_codesigning) 만든다.
#
# 이유: 클라우드 러너는 매번 새 기계라 keychain이 비휘발성이 아니다. 아카이브를
# 자동서명하면 xcodebuild가 매번 "Apple Development" 인증서를 새로 만들어 쓰는데,
# 그 개인키는 그 러너에서만 살고 러너가 사라지면 없어진다. 다음 빌드에서 Apple은
# "이 계정엔 이미 개발 인증서가 있는데 개인키가 없다 → 폐기 후 재발급 필요"라며
# 아카이브를 실패시킨다(실제 build 6 실패 원인). 개발 인증서를 아예 안 만들면
# 이 문제가 사라진다.
#
# 그래서: 아카이브는 서명 없이 만들고(skip_codesigning), export 단계에서만
# 클라우드 관리 "배포(Distribution)" 인증서로 서명한다. 배포 인증서는 App Store
# Connect API Key로 클라우드에서 관리돼(개인키를 Apple이 보관) 러너가 바뀌어도
# 재사용된다 → 반복 빌드에도 안정적.
#
# export 단계에서 배포 프로파일/인증서를 자동 생성하려면 API Key를 xcodebuild
# export 명령에 직접 넘겨야 한다(로그인 계정 없이). 안 넘기면 "No profiles were
# found" 로 export가 실패한다.
def signing_xcargs
  [
    "-allowProvisioningUpdates",
    "-authenticationKeyPath #{File.absolute_path(ENV['ASC_API_KEY_PATH'])}",
    "-authenticationKeyID #{ENV['ASC_KEY_ID']}",
    "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}",
    "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}"
  ].join(" ")
end

platform :ios do
  desc "빌드 후 TestFlight 업로드(스크린샷 불필요 — 첫 목표: 대표 아이폰 실기기 확인)"
  lane :beta do
    key = asc_key
    apply_automatic_signing
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      skip_codesigning: true,            # 아카이브는 서명 없이 → 개발 인증서 생성 안 함
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["APPLE_TEAM_ID"]
      },
      export_xcargs: signing_xcargs      # 서명은 export 단계에서만(클라우드 배포 인증서)
    )
    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "빌드 후 App Store Connect 업로드(메타데이터 포함). 심사 제출은 수동(대표 승인)."
  lane :release do
    key = asc_key
    apply_automatic_signing
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      skip_codesigning: true,            # 아카이브는 서명 없이 → 개발 인증서 생성 안 함
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["APPLE_TEAM_ID"]
      },
      export_xcargs: signing_xcargs      # 서명은 export 단계에서만(클라우드 배포 인증서)
    )
    upload_to_app_store(
      api_key: key,
      submit_for_review: false,   # 심사 제출은 사람이 최종 확인 후 수동으로.
      automatic_release: false,
      force: true,                # HTML 미리보기 창 없이 진행(CI).
      skip_screenshots: true,     # 스크린샷은 이후 단계에서 추가.
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end
end
